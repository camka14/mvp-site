{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MVP: Full Stack (Next + Chrome)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mvp: stop stale dev servers",
      "restart": false,
      "command": "npm run dev -- --webpack",
      "cwd": "${workspaceFolder}",
      "env": {
        "NGROK_DOMAIN": "untarnished-berserkly-everette.ngrok-free.dev",
        "MVP_DEV_ENABLE_NGROK": "1",
        "MVP_DEV_REQUIRE_NGROK": "1",
        "MVP_DEV_ENABLE_STRIPE_LISTEN": "1",
        "MVP_DEV_REQUIRE_STRIPE_LISTEN": "1"
      },
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "Local:\\s+(https?://[^\\s]+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}"
      }
    },
    {
      "name": "MVP: Full Stack (Next + Chrome + ngrok/stripe)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mvp: stop stale dev servers",
      "restart": false,
      "command": "npm run dev -- --webpack",
      "cwd": "${workspaceFolder}",
      "env": {
        "NGROK_DOMAIN": "untarnished-berserkly-everette.ngrok-free.dev",
        "MVP_DEV_ENABLE_NGROK": "1",
        "MVP_DEV_REQUIRE_NGROK": "1",
        "MVP_DEV_ENABLE_STRIPE_LISTEN": "1",
        "MVP_DEV_REQUIRE_STRIPE_LISTEN": "1"
      },
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "Local:\\s+(https?://[^\\s]+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}"
      }
    },
    {
      "name": "MVP: Backend Only (Next dev)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mvp: stop stale dev servers",
      "restart": false,
      "command": "npm run dev -- --webpack",
      "cwd": "${workspaceFolder}",
      "env": {
        "NGROK_DOMAIN": "untarnished-berserkly-everette.ngrok-free.dev",
        "MVP_DEV_ENABLE_NGROK": "1",
        "MVP_DEV_REQUIRE_NGROK": "1",
        "MVP_DEV_ENABLE_STRIPE_LISTEN": "1",
        "MVP_DEV_REQUIRE_STRIPE_LISTEN": "1"
      }
    }
  ]
}
