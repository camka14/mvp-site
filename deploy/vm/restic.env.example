# Copy to restic.env outside the repository and set mode 0600.
# Values are loaded by a POSIX shell, so quote values containing shell punctuation.
RESTIC_REPOSITORY=s3:https://sfo3.digitaloceanspaces.com/REPLACE_BUCKET/bracketiq-postgres
RESTIC_PASSWORD='REPLACE_WITH_A_LONG_RANDOM_REPOSITORY_PASSWORD'
AWS_ACCESS_KEY_ID='REPLACE_WITH_BACKUP_ONLY_SPACES_KEY'
AWS_SECRET_ACCESS_KEY='REPLACE_WITH_BACKUP_ONLY_SPACES_SECRET'
