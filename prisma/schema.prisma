  payoutProvider             String?
  payoutProviderTransferId   String?
  notes                      String?
  createdBy                  String?
  updatedBy                  String?

  @@index([payRunId])
  @@index([organizationId])
  @@index([staffMemberId])
  @@index([userId])
  @@index([eventId])
  @@index([teamId])
  @@index([eventTeamId])
  @@index([status])
  @@index([payoutStatus])
  @@index([serviceStartAt])
  @@index([serviceEndAt])
  @@index([approvedByUserId])
  @@index([paidByUserId])
}

model EventOfficials {
