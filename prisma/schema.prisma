  @@index([organizationId])
  @@index([teamId])
  @@index([eventTeamId])
  @@index([eventId])
  @@index([staffMemberId])
  @@index([userId])
  @@index([teamStaffAssignmentId])
  @@index([eventTeamStaffAssignmentId])
  @@index([status])
}

model FinancialLineItems {
  id             String                      @id
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  organizationId String
  eventId        String?
  teamId         String?
  eventTeamId    String?
  scope          FinancialLineItemScopeEnum
  category       String
