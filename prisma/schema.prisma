  rateOverrideCents  Int?
  status             StaffLaborStatusEnum            @default(PLANNED)
  notes              String?
  createdBy          String?
  updatedBy          String?

  @@index([organizationId])
  @@index([parentAssignmentId])
  @@index([staffMemberId])
  @@index([organizationRoleId])
  @@index([userId])
  @@index([assignmentKind])
  @@index([facilityId])
  @@index([fieldId])
  @@index([status])
  @@index([plannedStart])
  @@index([plannedEnd])
}

model TeamStaffLaborEntries {
  id                         String                    @id
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  organizationId             String
  teamId                     String?
  eventTeamId                String?
