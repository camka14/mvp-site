  @@index([organizationId])
  @@index([periodStart])
  @@index([periodEnd])
  @@index([scheduledPayDate])
  @@index([status])
  @@index([payoutStatus])
  @@index([approvedByUserId])
  @@index([paidByUserId])
  @@index([exportedByUserId])
}

model StaffPayRunItem {
  id                         String                    @id
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  payRunId                   String
  organizationId             String
  staffMemberId              String?
  userId                     String
  eventId                    String?
  teamId                     String?
  eventTeamId                String?
  eventStaffAssignmentId     String?                   @unique
  staffScheduleAssignmentId  String?
  staffScheduleOccurrenceKey String?                   @unique
  teamStaffLaborEntryId      String?                   @unique
  label                      String
