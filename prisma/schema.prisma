  updatedBy      String?

  @@index([organizationId])
  @@index([eventId])
  @@index([teamId])
  @@index([eventTeamId])
  @@index([scope])
  @@index([category])
  @@index([status])
  @@index([occurredAt])
  @@index([serviceStartAt])
  @@index([serviceEndAt])
}

model StaffPayRun {
