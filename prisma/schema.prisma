model AppReleases {
  id                 String                 @id
  platform           AppReleasePlatformEnum
  versionName        String
  buildNumber        Int?
  changes            String[]               @default([])
  hasBreakingChanges Boolean                @default(false)
  isActive           Boolean                @default(true)
  updateUrl          String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([platform, isActive])
  @@index([platform, buildNumber])
  @@index([platform, versionName])
}

model Fields {
  id               String    @id
  createdAt        DateTime?
  updatedAt        DateTime?
  archivedAt       DateTime?
  archivedByUserId String?
  archiveReason    String?
  lat              Float?
  long             Float?
  heading          Float?
  inUse            Boolean?
  name             String?
  rentalSlotIds    String[]
  location         String?
  organizationId   String?
  facilityId       String?
  createdBy        String?

  @@index([organizationId])
  @@index([facilityId])
  @@index([createdBy])
  @@index([archivedAt])
}

model Facilities {
  id             String    @id
  createdAt      DateTime? @default(now())
  updatedAt      DateTime? @updatedAt
  organizationId String
  name           String
  location       String
  address        String?
  coordinates    Json?
  operatingHours Json?
  timeZone       String    @default("UTC")
  status         String    @default("ACTIVE")
  isDefault      Boolean   @default(false)
  sortOrder      Int?
  affiliateUrl   String?

  @@index([organizationId])
  @@index([organizationId, isDefault])
  @@index([status])
  @@index([affiliateUrl])
}

model Matches {
  id                 String    @id
  createdAt          DateTime?
  updatedAt          DateTime?
  start              DateTime?
  end                DateTime?
  locked             Boolean   @default(false)
  division           String?
  team1Points        Int[]
  team2Points        Int[]
  setResults         Int[]
  side               String?
  matchId            Int
  losersBracket      Boolean?
  status             String?
  resultStatus       String?
  resultType         String?
  actualStart        DateTime?
  actualEnd          DateTime?
  statusReason       String?
  winnerEventTeamId  String?
  matchRulesSnapshot Json?
  winnerNextMatchId  String?
  loserNextMatchId   String?
  previousRightId    String?
  previousLeftId     String?
  officialCheckedIn  Boolean?
  officialId         String?
  officialIds        Json?
  team1Id            String?
  team2Id            String?
  team1Seed          Int?
  team2Seed          Int?
  eventId            String?
  fieldId            String?
  teamOfficialId     String?

  @@index([eventId])
  @@index([matchId])
  @@index([winnerNextMatchId])
  @@index([loserNextMatchId])
  @@index([previousLeftId])
  @@index([previousRightId])
  @@index([fieldId])
  @@index([winnerEventTeamId])
}

model MatchSegments {
  id                String    @id
  createdAt         DateTime?
  updatedAt         DateTime?
  eventId           String?
  matchId           String
  sequence          Int
  status            String    @default("NOT_STARTED")
  scores            Json
  winnerEventTeamId String?
  startedAt         DateTime?
  endedAt           DateTime?
  resultType        String?
  statusReason      String?
  metadata          Json?

  @@unique([matchId, sequence])
  @@index([eventId])
  @@index([matchId])
  @@index([winnerEventTeamId])
}

model MatchIncidents {
  id                  String    @id
  createdAt           DateTime?
  updatedAt           DateTime?
  eventId             String?
  matchId             String
  segmentId           String?
  eventTeamId         String?
  eventRegistrationId String?
  participantUserId   String?
  officialUserId      String?
  incidentType        String
  sequence            Int
  minute              Int?
  clock               String?
  clockSeconds        Int?
  linkedPointDelta    Int?
  note                String?
  metadata            Json?

  @@index([eventId])
  @@index([matchId])
  @@index([segmentId])
  @@index([eventTeamId])
  @@index([eventRegistrationId])
  @@index([participantUserId])
  @@index([officialUserId])
}

model Divisions {
  id                                  String             @id
  createdAt                           DateTime?
  updatedAt                           DateTime?
  name                                String
  key                                 String?
  kind                                DivisionsKindEnum? @default(LEAGUE)
  sortOrder                           Int?
  eventId                             String?
  organizationId                      String?
  sportId                             String?
  price                               Int?
  maxParticipants                     Int?
  playoffTeamCount                    Int?
  playoffPlacementDivisionIds         String[]           @default([])
  standingsOverrides                  Json?
  gamesPerOpponent                    Int?
  restTimeMinutes                     Int?
  usesSets                            Boolean?
  matchDurationMinutes                Int?
  setDurationMinutes                  Int?
  setsPerMatch                        Int?
  pointsToVictory                     Int[]              @default([])
  playoffDoubleElimination            Boolean?
  playoffWinnerSetCount               Int?
  playoffLoserSetCount                Int?
  playoffWinnerBracketPointsToVictory Int[]              @default([])
  playoffLoserBracketPointsToVictory  Int[]              @default([])
  playoffPrize                        String?
  playoffFieldCount                   Int?
  playoffRestTimeMinutes              Int?
  playoffMatchDurationMinutes         Int?
  playoffSetDurationMinutes           Int?
  standingsConfirmedAt                DateTime?
  standingsConfirmedBy                String?
  allowPaymentPlans                   Boolean?
  installmentCount                    Int?
  installmentDueDates                 DateTime[]         @default([])
  installmentDueRelativeDays          Int[]              @default([])
  installmentAmounts                  Int[]              @default([])
  minRating                           Float?
  maxRating                           Float?
  divisionTypeId                      String?
  ratingType                          String?
  gender                              String?
  ageCutoffDate                       DateTime?
  ageCutoffLabel                      String?
  ageCutoffSource                     String?
  fieldIds                            String[]           @default([])
  teamIds                             String[]           @default([])

  @@index([eventId])
  @@index([eventId, kind, sortOrder])
  @@index([organizationId])
  @@index([sportId])
  @@index([key])
}

model UserData {
  id                               String    @id
  createdAt                        DateTime?
  updatedAt                        DateTime?
  firstName                        String?
  lastName                         String?
  dateOfBirth                      DateTime
  requiredProfileFieldsCompletedAt DateTime?
  dobVerified                      Boolean?
  dobVerifiedAt                    DateTime?
  ageVerificationProvider          String?
  teamIds                          String[]
  friendIds                        String[]
  userName                         String
  hasStripeAccount                 Boolean?
  followingIds                     String[]
  friendRequestIds                 String[]
  friendRequestSentIds             String[]
  uploadedImages                   String[]
  profileImageId                   String?
  homePageOrganizationId           String?
  blockedUserIds                   String[]  @default([])
  hiddenEventIds                   String[]  @default([])
  chatTermsAcceptedAt              DateTime?
  chatTermsVersion                 String?
  onboardingIntent                 String?
  accountVisibility                String    @default("PUBLIC")
  notificationSettings             Json      @default("{}")

  @@index([accountVisibility])
}

model SensitiveUserData {
  id                            String    @id
  createdAt                     DateTime?
  updatedAt                     DateTime?
  userId                        String
  email                         String
  billingAddressLine1           String?
  billingAddressLine2           String?
  billingCity                   String?
  billingState                  String?
  billingPostalCode             String?
  billingCountryCode            String?
  appleRefreshToken             String?
  phoneNumberE164               String?
  phoneVerifiedAt               DateTime?
  phoneVerificationProvider     String?
  phoneVerificationLastSentAt   DateTime?
  phoneVerificationAttemptCount Int       @default(0)
  totpSecretEncrypted           String?
  totpEnabledAt                 DateTime?
  totpVerifiedAt                DateTime?
  totpLastUsedCounter           Int?
  totpProvider                  String?
  financialMfaRequiredAt        DateTime?
  financialMfaSatisfiedAt       DateTime?

  @@index([userId])
  @@index([phoneVerifiedAt])
  @@index([totpEnabledAt])
}

model AuthMfaChallenges {
  id                    String                      @id
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  userId                String
  purpose               AuthMfaChallengePurposeEnum
  phoneNumberE164       String?
  totpSecretEncrypted   String?
  provider              String
  providerChallengeId   String?
  devCodeHash           String?
  expiresAt             DateTime
  consumedAt            DateTime?
  lastSentAt            DateTime?
  attemptCount          Int                         @default(0)
  sessionVersion        Int                         @default(0)
  verificationIpHash    String?
  verificationUserAgent String?

  @@index([userId, purpose, consumedAt])
  @@index([expiresAt])
}

model Invites {
  id             String    @id
  createdAt      DateTime?
  updatedAt      DateTime?
  sentAt         DateTime?
  type           String
  email          String
  status         String?
  staffTypes     String[]  @default([])
  eventId        String?
  organizationId String?
  teamId         String?
  userId         String?
  createdBy      String?
  firstName      String?
  lastName       String?
}

model TeamInviteEventSyncs {
  id                           String                        @id
  createdAt                    DateTime?
  updatedAt                    DateTime?
  inviteId                     String
  canonicalTeamId              String
  eventId                      String
  eventTeamId                  String
  userId                       String
  previousRegistrationSnapshot Json?
  eventTeamHadUser             Boolean                       @default(false)
  eventTeamHadPendingUser      Boolean                       @default(false)
  sourceTeamRegistrationId     String?
  status                       TeamInviteEventSyncStatusEnum @default(PENDING)

  @@unique([inviteId, eventTeamId, userId])
  @@index([inviteId])
  @@index([canonicalTeamId])
  @@index([eventId])
  @@index([eventTeamId])
  @@index([userId])
}

model StaffMembers {
  id             String    @id
  createdAt      DateTime?
  updatedAt      DateTime?
  organizationId String
  userId         String
  types          String[]  @default([])
  roleId         String?

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([roleId])
}

model OrganizationRoles {
  id             String    @id
  createdAt      DateTime?
  updatedAt      DateTime?
  organizationId String
  name           String
  kind           String
  systemKey      String?
  isSystem       Boolean   @default(false)
  isDefault      Boolean   @default(false)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([systemKey])
}

model OrganizationRolePermissions {
  id                 String    @id
  createdAt          DateTime?
  updatedAt          DateTime?
  organizationRoleId String
  permission         String

  @@unique([organizationRoleId, permission])
  @@index([organizationRoleId])
  @@index([permission])
}

model OrganizationRoleCompensationRates {
  id                 String                   @id
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  organizationId     String
  organizationRoleId String
  wageType           CompensationWageTypeEnum
  amountCents        Int
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  createdBy          String?
  updatedBy          String?

  @@index([organizationId])
  @@index([organizationRoleId])
  @@index([organizationRoleId, effectiveFrom], map: "OrgRoleCompRates_role_effectiveFrom_idx")
  @@index([organizationRoleId, effectiveTo], map: "OrgRoleCompRates_role_effectiveTo_idx")
}

model StaffCompensationRates {
  id             String                   @id
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organizationId String
  staffMemberId  String
  wageType       CompensationWageTypeEnum
  amountCents    Int
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  createdBy      String?
  updatedBy      String?

  @@index([organizationId])
  @@index([staffMemberId])
  @@index([staffMemberId, effectiveFrom])
  @@index([staffMemberId, effectiveTo])
}

model EventStaffAssignments {
  id                 String                    @id
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  organizationId     String
  eventId            String
  staffMemberId      String
  organizationRoleId String?
  userId             String?
  plannedStart       DateTime?
  plannedEnd         DateTime?
  actualStart        DateTime?
  actualEnd          DateTime?
  plannedMinutes     Int?
  actualMinutes      Int?
  rateOverrideType   CompensationWageTypeEnum?
  rateOverrideCents  Int?
  status             StaffLaborStatusEnum      @default(PLANNED)
  notes              String?
  createdBy          String?
  updatedBy          String?

  @@index([organizationId])
  @@index([eventId])
  @@index([staffMemberId])
  @@index([organizationRoleId])
  @@index([status])
}

model StaffScheduleAssignments {
  id                 String                          @id
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt
  organizationId     String
  parentAssignmentId String?
  staffMemberId      String?
  organizationRoleId String?
  userId             String?
